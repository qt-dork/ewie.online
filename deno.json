{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/yaml": "jsr:@std/yaml@^1.1.2",
    "lume/": "https://deno.land/x/lume@v3.2.5/",
    "lume/cms/": "https://cdn.jsdelivr.net/gh/lumeland/cms@0.15.7/",
    "lume/jsx-runtime": "https://deno.land/x/ssx@v0.1.15/jsx-runtime.ts"
  },
  "tasks": {
    "lume": "echo \"import 'lume/cli.ts'\" | deno run -A -",
    "build": "deno task lume",
    "serve": "deno task lume -s",
    "update-deps": "deno run -A --quiet 'https://deno.land/x/nudd@v0.2.13/cli.ts' update plugins.ts deno.json",
    "cms": "deno task lume cms",
    "debug": "echo \"import 'lume/cli.ts'\" | deno run --inspect-wait --unstable -A -"
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "lint": {
    "exclude": [
      "./_site"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "plugins": [
      "https://deno.land/x/lume@v3.2.5/lint.ts"
    ]
  },
  "fmt": {
    "exclude": [
      "./_site"
    ]
  },
  "unstable": [
    "temporal",
    "fmt-component"
  ]
}
